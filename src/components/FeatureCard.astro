---
// Problem·Services 공통 카드.
//  - step 전달 시      → 아이콘 옆 STEP 배지 (Services)
//  - example 전달 시   → 샘플 메시지 말풍선 (Services)
//  - highlight 전달 시 → 강조 결론 문장 (Problem)
//  - metric 전달 시    → 하단 성과 지표
interface Props {
  icon: string; // Phosphor 클래스 (regular)
  title: string;
  body?: string;
  step?: string;
  example?: string;
  highlight?: string;
  metric?: { prefix: string; value: string; suffix: string };
}
const { icon, title, body, step, example, highlight, metric } = Astro.props;
---

<article
  class="lift-card flex flex-col rounded-2xl border border-gray-100 bg-white p-4 text-center shadow-sm lg:rounded-4xl lg:p-10"
>
  <div class="mb-3 flex items-center justify-center gap-2 lg:mb-10 lg:gap-4">
    <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-coral/10 lg:h-16 lg:w-16 lg:rounded-2xl">
      <i class:list={['ph', icon, 'text-lg text-coral lg:text-3xl']} aria-hidden="true"></i>
    </div>
    {step && <span class="text-base font-bold uppercase tracking-wider text-coral">{step}</span>}
  </div>
  <h3 class="mb-2 text-[13px] font-bold leading-snug lg:mb-6 lg:text-xl">{title}</h3>
  <div class="space-y-2 text-[11px] font-light leading-relaxed text-gray-500 lg:space-y-4 lg:text-base">
    {body && <p set:html={body} />}
    {
      example && (
        <p class="rounded-xl bg-coral/5 px-4 py-3 text-sm font-medium text-gray-600">
          “{example}”
        </p>
      )
    }
    {highlight && <p class="pt-1 font-semibold text-gray-900 lg:pt-2">{highlight}</p>}
    {
      metric && metric.value && (
        <div class="mt-4 border-t border-gray-100 pt-4">
          <p class="text-sm font-medium text-gray-400">
            {metric.prefix}{' '}
            <span class="text-lg font-bold text-coral">{metric.value}</span>{' '}
            {metric.suffix}
          </p>
        </div>
      )
    }
  </div>
</article>
