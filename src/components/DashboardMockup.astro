---
// 히어로 우측 대시보드 목업
// "취소 발생 → 럭키딜 알림 → 자동 재예약 → 매출 복구"를 CSS 시퀀스로 재생.
// 애니메이션 정의는 src/styles/global.css (booking-card / empty-slot / earnings-panel).
const now = new Date();
const days = ['일', '월', '화', '수', '목', '금', '토'];
const today = `${now.getFullYear()}년 ${now.getMonth() + 1}월 ${now.getDate()}일 (${days[now.getDay()]})`;
---

<div class="dashboard-container group relative">
  <!-- 배경 blur blob (히어로 임팩트용 — 코랄 글로우 강화) -->
  <div class="absolute -right-12 -top-12 h-72 w-72 rounded-full bg-coral opacity-[0.13] blur-3xl"></div>
  <div class="absolute -bottom-12 -left-12 h-72 w-72 rounded-full bg-gold opacity-[0.08] blur-3xl"></div>

  <div
    class="relative mx-auto aspect-auto w-full max-w-[680px] overflow-hidden rounded-4xl border border-gray-100 bg-white shadow-float transition-transform duration-500 ease-out group-hover:-translate-y-1.5 lg:aspect-[4/3]"
  >
    <!-- 헤더 -->
    <div class="flex items-center justify-between border-b border-gray-50 bg-[#FBFBFB] px-5 py-4 lg:px-8 lg:py-6">
      <div class="flex items-center gap-4">
        <div class="flex gap-1.5">
          <div class="h-3 w-3 rounded-full bg-red-200"></div>
          <div class="h-3 w-3 rounded-full bg-yellow-200"></div>
          <div class="h-3 w-3 rounded-full bg-green-200"></div>
        </div>
        <h3 class="flex items-center gap-2 font-semibold text-gray-800">
          <i class="ph ph-calendar text-gray-400" aria-hidden="true"></i>
          {today}
        </h3>
      </div>
      <div class="flex items-center gap-2">
        <button class="rounded-lg p-2 text-gray-400 hover:bg-gray-100" aria-label="이전 날짜">
          <i class="ph ph-caret-left" aria-hidden="true"></i>
        </button>
        <button class="rounded-lg p-2 text-gray-400 hover:bg-gray-100" aria-label="다음 날짜">
          <i class="ph ph-caret-right" aria-hidden="true"></i>
        </button>
      </div>
    </div>

    <!-- 타임라인 (모바일 <640px 압축 / sm 이상 기존 풀사이즈) -->
    <div class="flex h-full flex-col p-3 sm:p-5 lg:p-8">
      <div class="relative grid flex-grow grid-cols-[44px_1fr] gap-3 sm:grid-cols-[80px_1fr] sm:gap-6">
        <!-- 시간축 -->
        <div class="space-y-[74px] pt-1">
          <div class="text-right text-[9px] font-medium text-gray-400 sm:text-xs">오전 11:00</div>
          <div class="text-right text-[9px] font-medium text-gray-400 sm:text-xs">오후 12:00</div>
          <div class="text-right text-[9px] font-medium text-gray-400 sm:text-xs">오후 01:00</div>
          <div class="text-right text-[9px] font-medium text-gray-400 sm:text-xs">오후 02:00</div>
          <div class="text-right text-[9px] font-medium text-gray-400 sm:text-xs">오후 03:00</div>
        </div>

        <!-- 예약 슬롯 -->
        <div class="relative space-y-4">
          <!-- 그리드 라인 -->
          <div class="pointer-events-none absolute inset-0 space-y-[90px] pt-3">
            <div class="w-full border-b border-gray-100"></div>
            <div class="w-full border-b border-gray-100"></div>
            <div class="w-full border-b border-gray-100"></div>
            <div class="w-full border-b border-gray-100"></div>
            <div class="w-full border-b border-gray-100"></div>
          </div>

          <!-- 확정 예약 -->
          <div class="relative z-10 flex h-20 w-full items-center gap-2 rounded-xl border border-gray-100 bg-gray-50 p-2.5 sm:gap-4 sm:p-4">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-blue-100 text-xs font-bold text-blue-600 sm:h-10 sm:w-10 sm:text-base">K</div>
            <div class="min-w-0">
              <div class="truncate text-xs font-semibold sm:text-sm">김서연 고객님</div>
              <div class="truncate text-[10px] tracking-widest text-gray-400">커트 + 펌</div>
            </div>
            <div class="ml-auto shrink-0 whitespace-nowrap rounded bg-blue-50 px-1.5 py-0.5 text-[9px] font-bold text-blue-500 sm:px-2 sm:text-[10px]">예약확정</div>
          </div>

          <!-- 빈 슬롯 → 자동 재예약 -->
          <div class="relative flex h-[164px] w-full items-center justify-center rounded-xl">
            <div class="empty-slot absolute inset-0 z-0 rounded-xl border-2 border-dashed"></div>
            <div class="empty-label z-10 text-center">
              <div class="mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-full bg-coral/10">
                <i class="ph ph-warning-circle text-xl text-coral" aria-hidden="true"></i>
              </div>
              <p class="text-xs font-semibold text-coral">취소 발생 (2시간)</p>
              <p class="mt-1 text-[10px] text-gray-400">대기 고객 12명 알림 전송됨</p>
            </div>

            <div class="booking-card absolute inset-0 z-20 flex flex-col justify-between rounded-xl bg-coral p-4 shadow-xl sm:p-6">
              <div class="flex items-start justify-between gap-2">
                <div class="flex min-w-0 items-center gap-2 sm:gap-3">
                  <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-white/30 bg-white/20 text-sm font-bold text-white sm:h-12 sm:w-12 sm:text-lg">L</div>
                  <div class="min-w-0">
                    <div class="truncate text-[13px] font-bold text-white sm:text-lg">이민지 고객님</div>
                    <div class="truncate text-[10px] font-medium text-white/70 sm:text-xs">프리미엄 펌·염색 (2시간)</div>
                  </div>
                </div>
                <div class="shrink-0 rounded-full border border-white/30 bg-white/20 px-2 py-1 backdrop-blur-md sm:px-3 sm:py-1.5">
                  <span class="flex items-center gap-1 whitespace-nowrap text-[9px] font-bold text-white sm:gap-1.5 sm:text-[10px] sm:tracking-widest">
                    <i class="ph-fill ph-lightning" aria-hidden="true"></i> AI 자동배정
                  </span>
                </div>
              </div>
              <div class="mt-auto flex items-center justify-between border-t border-white/20 pt-2.5 text-white sm:pt-4">
                <div class="text-[10px] font-medium opacity-90 sm:text-xs">13:00 - 15:00</div>
                <div class="flex items-center gap-1.5 sm:gap-2">
                  <i class="ph ph-check-circle text-base sm:text-xl" aria-hidden="true"></i>
                  <span class="whitespace-nowrap text-[10px] font-bold sm:text-xs">재예약 완료</span>
                </div>
              </div>
            </div>
          </div>

          <!-- 흐린 예약 -->
          <div class="relative z-10 flex h-20 w-full items-center gap-2 rounded-xl border border-gray-100 bg-gray-50 p-2.5 opacity-50 sm:gap-4 sm:p-4">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-purple-100 text-xs font-bold text-purple-600 sm:h-10 sm:w-10 sm:text-base">P</div>
            <div class="min-w-0">
              <div class="truncate text-xs font-semibold sm:text-sm">박지호 고객님</div>
              <div class="truncate text-[10px] text-gray-400">남성 커트</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 매출 복구 알림 (2.8s 후 등장) -->
    <div
      class="earnings-panel glass-panel absolute bottom-3 right-3 z-30 flex items-center gap-2 rounded-2xl border border-white/50 p-2.5 shadow-xl sm:gap-4 sm:p-4 lg:bottom-8 lg:right-8"
    >
      <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-green-500 text-white shadow-lg shadow-green-200 sm:h-10 sm:w-10">
        <i class="ph ph-trend-up text-base sm:text-xl" aria-hidden="true"></i>
      </div>
      <div>
        <p class="mb-0.5 text-[9px] font-bold leading-none tracking-widest text-gray-400 sm:mb-1 sm:text-[10px]">예상 회수 매출</p>
        <p class="whitespace-nowrap text-sm font-bold text-gray-900 sm:text-lg">
          +128,000원 <span class="ml-0.5 text-[10px] font-medium text-green-500 sm:ml-1 sm:text-sm">복구완료</span>
        </p>
      </div>
    </div>
  </div>
</div>
