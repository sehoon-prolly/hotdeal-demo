---
// 히어로 우측 대시보드 목업
// "취소 발생 → 핫딜 알림 → 자동 재예약 → 매출 복구"를 CSS 시퀀스로 재생.
// 애니메이션 정의는 src/styles/global.css (booking-card / empty-slot / earnings-panel).
---

<div class="dashboard-container relative">
  <!-- 배경 blur blob -->
  <div class="absolute -right-10 -top-10 h-64 w-64 rounded-full bg-coral opacity-[0.08] blur-3xl"></div>
  <div class="absolute -bottom-10 -left-10 h-64 w-64 rounded-full bg-gold opacity-[0.05] blur-3xl"></div>

  <div
    class="relative aspect-[4/3] w-full max-w-[620px] overflow-hidden rounded-4xl border border-gray-100 bg-white shadow-card"
  >
    <!-- 헤더 -->
    <div class="flex items-center justify-between border-b border-gray-50 bg-[#FBFBFB] px-8 py-6">
      <div class="flex items-center gap-4">
        <div class="flex gap-1.5">
          <div class="h-3 w-3 rounded-full bg-red-200"></div>
          <div class="h-3 w-3 rounded-full bg-yellow-200"></div>
          <div class="h-3 w-3 rounded-full bg-green-200"></div>
        </div>
        <h3 class="flex items-center gap-2 font-semibold text-gray-800">
          <i class="ph ph-calendar text-gray-400" aria-hidden="true"></i>
          2024년 3월 24일 (일)
        </h3>
      </div>
      <div class="flex items-center gap-2">
        <button class="rounded-lg p-2 text-gray-400 hover:bg-gray-100" aria-label="이전 날짜">
          <i class="ph ph-caret-left" aria-hidden="true"></i>
        </button>
        <button class="rounded-lg p-2 text-gray-400 hover:bg-gray-100" aria-label="다음 날짜">
          <i class="ph ph-caret-right" aria-hidden="true"></i>
        </button>
      </div>
    </div>

    <!-- 타임라인 -->
    <div class="flex h-full flex-col p-8">
      <div class="relative grid flex-grow grid-cols-[80px_1fr] gap-6">
        <!-- 시간축 -->
        <div class="space-y-[74px] pt-1">
          <div class="text-right text-xs font-medium text-gray-400">오전 11:00</div>
          <div class="text-right text-xs font-medium text-gray-400">오후 12:00</div>
          <div class="text-right text-xs font-medium text-gray-400">오후 01:00</div>
          <div class="text-right text-xs font-medium text-gray-400">오후 02:00</div>
          <div class="text-right text-xs font-medium text-gray-400">오후 03:00</div>
        </div>

        <!-- 예약 슬롯 -->
        <div class="relative space-y-4">
          <!-- 그리드 라인 -->
          <div class="pointer-events-none absolute inset-0 space-y-[90px] pt-3">
            <div class="w-full border-b border-gray-100"></div>
            <div class="w-full border-b border-gray-100"></div>
            <div class="w-full border-b border-gray-100"></div>
            <div class="w-full border-b border-gray-100"></div>
            <div class="w-full border-b border-gray-100"></div>
          </div>

          <!-- 확정 예약 -->
          <div class="relative z-10 flex h-20 w-full items-center gap-4 rounded-xl border border-gray-100 bg-gray-50 p-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-100 font-bold text-blue-600">K</div>
            <div>
              <div class="text-sm font-semibold">김서연 고객님</div>
              <div class="text-[10px] uppercase tracking-widest text-gray-400">Hair Cut &amp; Perm</div>
            </div>
            <div class="ml-auto rounded bg-blue-50 px-2 py-0.5 text-[10px] font-bold uppercase text-blue-500">Confirmed</div>
          </div>

          <!-- 빈 슬롯 → 자동 재예약 -->
          <div class="relative flex h-[164px] w-full items-center justify-center rounded-xl">
            <div class="empty-slot absolute inset-0 z-0 rounded-xl border-2 border-dashed"></div>
            <div class="empty-label z-10 text-center">
              <div class="mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-full bg-coral/10">
                <i class="ph ph-warning-circle text-xl text-coral" aria-hidden="true"></i>
              </div>
              <p class="text-xs font-semibold text-coral">취소 발생 (2시간)</p>
              <p class="mt-1 text-[10px] text-gray-400">대기 고객 12명 알림 전송됨</p>
            </div>

            <div class="booking-card absolute inset-0 z-20 flex flex-col justify-between rounded-xl bg-coral p-6 shadow-xl">
              <div class="flex items-start justify-between">
                <div class="flex items-center gap-3">
                  <div class="flex h-12 w-12 items-center justify-center rounded-full border border-white/30 bg-white/20 text-lg font-bold text-white">L</div>
                  <div>
                    <div class="text-lg font-bold text-white">이민지 고객님</div>
                    <div class="text-xs font-medium text-white/70">Premium Hair Spa (2hr)</div>
                  </div>
                </div>
                <div class="rounded-full border border-white/30 bg-white/20 px-3 py-1.5 backdrop-blur-md">
                  <span class="flex items-center gap-1.5 text-[10px] font-bold tracking-widest text-white">
                    <i class="ph-fill ph-lightning" aria-hidden="true"></i> AI AUTOMATED
                  </span>
                </div>
              </div>
              <div class="mt-auto flex items-center justify-between border-t border-white/20 pt-4 text-white">
                <div class="text-xs font-medium opacity-90">13:00 - 15:00</div>
                <div class="flex items-center gap-2">
                  <i class="ph ph-check-circle text-xl" aria-hidden="true"></i>
                  <span class="text-xs font-bold">RE-BOOKED</span>
                </div>
              </div>
            </div>
          </div>

          <!-- 흐린 예약 -->
          <div class="relative z-10 flex h-20 w-full items-center gap-4 rounded-xl border border-gray-100 bg-gray-50 p-4 opacity-50">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-purple-100 font-bold text-purple-600">P</div>
            <div>
              <div class="text-sm font-semibold">박지호 고객님</div>
              <div class="text-[10px] text-gray-400">Portrait Session</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 매출 복구 알림 (2.8s 후 등장) -->
    <div
      class="earnings-panel glass-panel absolute bottom-8 right-8 flex items-center gap-4 rounded-2xl border border-white/50 p-4 shadow-xl"
    >
      <div class="flex h-10 w-10 items-center justify-center rounded-full bg-green-500 text-white shadow-lg shadow-green-200">
        <i class="ph ph-trend-up text-xl" aria-hidden="true"></i>
      </div>
      <div>
        <p class="mb-1 text-[10px] font-bold uppercase leading-none tracking-widest text-gray-400">Estimated Earnings</p>
        <p class="text-lg font-bold text-gray-900">
          +128,000원 <span class="ml-1 text-sm font-medium text-green-500">복구완료</span>
        </p>
      </div>
    </div>
  </div>
</div>
