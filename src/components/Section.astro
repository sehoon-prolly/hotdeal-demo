---
// 공통 섹션 래퍼 — 최대 폭·좌우/상하 여백을 한 곳에서 관리 (반응형 패딩 포함)
interface Props {
  id?: string;
  class?: string;
}
const { id, class: className = '' } = Astro.props;
---

<section
  id={id}
  class:list={[
    'mx-auto w-full max-w-container px-6 py-20 md:px-12 md:py-32',
    className,
  ]}
>
  <slot />
</section>
