---
// 공통 섹션 래퍼 — 최대 폭·여백을 한 곳에서 관리.
// bg로 풀폭 배경 밴드를 교차(cream/sand)시켜 섹션 리듬을 만든다.
// 배경은 바깥 <section>(풀폭), 콘텐츠 패딩·reveal은 안쪽 div에 둔다
//  → reveal의 translate가 배경 밴드를 흔들지 않음.
interface Props {
  id?: string;
  class?: string;
  bg?: 'cream' | 'sand';
  tight?: boolean; // 모바일 상하 패딩 축소 (웹은 동일)
}
const { id, class: className = '', bg = 'cream', tight = false } = Astro.props;
const bgClass = bg === 'sand' ? 'bg-sand' : 'bg-cream';
const padY = tight ? 'py-12 md:py-32' : 'py-20 md:py-32';
---

<section id={id} class:list={['w-full', bgClass]}>
  <div
    class:list={[
      'mx-auto w-full max-w-container px-6 md:px-12',
      padY,
      className,
    ]}
  >
    <slot />
  </div>
</section>
