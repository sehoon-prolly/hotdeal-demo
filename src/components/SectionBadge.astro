---
// 섹션 상단 코랄 뱃지 (예: "02 Problem")
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div
  class:list={[
    'mb-6 inline-flex items-center gap-2 rounded-full bg-coral/10 px-3 py-1 text-xs font-bold uppercase tracking-wider text-coral',
    className,
  ]}
>
  <slot />
</div>
