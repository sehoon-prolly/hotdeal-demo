---
// Problem 핵심 인포그래픽 — 줄글 대신 손실을 '보여준다'.
//  좌: 하루 예약표에서 취소 슬롯이 ₩0이 되고 앞뒤 시간까지 막히는 모습
//  우: 1건 → 한 달 → 1년으로 손실이 쌓이는 누적 막대
// 전부 HTML/CSS (자산 0). 수치는 problems.ts 기조(펌·염색 ~15만 / 연 180만+)와 일치.
---

<div
  class="grid gap-4 rounded-3xl border border-gray-100 bg-white p-4 shadow-card md:grid-cols-2 md:gap-8 md:rounded-4xl md:p-10"
>
  <!-- 좌: 하루 예약표 -->
  <div>
    <p class="mb-3 flex items-center gap-2 text-xs font-bold text-gray-700 md:mb-5 md:text-sm">
      <i class="ph ph-calendar-blank text-coral" aria-hidden="true"></i> 오늘 예약 현황
    </p>
    <div class="space-y-1.5 md:space-y-2.5">
      <!-- 정상 예약 -->
      <div class="flex items-center gap-2 rounded-xl border border-gray-100 bg-gray-50 px-3 py-2 md:gap-3 md:px-4 md:py-3">
        <span class="w-9 shrink-0 text-[11px] font-medium text-gray-400 md:w-12 md:text-xs">11:00</span>
        <span class="text-xs font-semibold text-gray-700 md:text-sm">김OO · 커트</span>
        <span class="ml-auto rounded bg-blue-50 px-2 py-0.5 text-[10px] font-bold text-blue-500">확정</span>
      </div>

      <!-- 취소된 슬롯 → ₩0 -->
      <div class="flex items-center gap-2 rounded-xl border-2 border-dashed border-coral/50 bg-coral/5 px-3 py-2.5 md:gap-3 md:px-4 md:py-4">
        <span class="w-9 shrink-0 text-[11px] font-medium text-coral/70 md:w-12 md:text-xs">13:00</span>
        <div class="min-w-0">
          <p class="truncate text-xs font-bold text-coral line-through decoration-coral/50 md:text-sm">
            펌·염색 (2시간)
          </p>
          <p class="text-[10px] font-medium text-gray-400 md:text-[11px]">직전 취소 발생</p>
        </div>
        <span class="ml-auto text-base font-extrabold text-coral md:text-xl">₩0</span>
      </div>

      <!-- 앞뒤 막힘 -->
      <div class="flex items-center gap-2 rounded-xl border border-gray-100 bg-gray-50 px-3 py-2 opacity-60 md:gap-3 md:px-4 md:py-3">
        <span class="w-9 shrink-0 text-[11px] font-medium text-gray-400 md:w-12 md:text-xs">15:00</span>
        <span class="text-xs font-medium text-gray-500 md:text-sm">앞뒤 시간도 예약 못 받음</span>
        <i class="ph ph-prohibit ml-auto shrink-0 text-gray-400" aria-hidden="true"></i>
      </div>
    </div>
  </div>

  <!-- 우: 손실 누적 -->
  <div
    class="flex flex-col justify-center border-t border-gray-100 pt-4 md:border-l md:border-t-0 md:pl-10 md:pt-0"
  >
    <p class="mb-3 text-xs font-bold text-gray-700 md:mb-5 md:text-sm">이렇게 쌓입니다</p>
    <div class="space-y-2 md:space-y-3">
      <div class="flex items-end justify-between">
        <span class="text-xs text-gray-500 md:text-sm">취소 1건</span>
        <span class="text-sm font-bold text-gray-700 md:text-base">−15만원</span>
      </div>
      <div class="h-2 w-1/4 rounded-full bg-coral/30"></div>

      <div class="flex items-end justify-between pt-0.5 md:pt-1">
        <span class="text-xs text-gray-500 md:text-sm">한 달 3건</span>
        <span class="text-sm font-bold text-gray-700 md:text-base">−45만원</span>
      </div>
      <div class="h-2 w-1/2 rounded-full bg-coral/50"></div>

      <div class="flex items-end justify-between pt-0.5 md:pt-1">
        <span class="text-xs font-semibold text-ink md:text-sm">1년이면</span>
        <span class="text-xl font-extrabold text-coral md:text-2xl">−180만원+</span>
      </div>
      <div class="h-2.5 w-full rounded-full bg-coral"></div>
    </div>
  </div>
</div>
