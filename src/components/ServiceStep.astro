---
// Services 스텝 카드 — 상단에 '화면 목업'(slot), 하단에 스텝/제목/캡션.
// 목업은 각 스텝마다 다르므로 Services.astro에서 slot으로 주입한다.
interface Props {
  step: string;
  title: string;
  caption: string;
}
const { step, title, caption } = Astro.props;
---

<article class="lift-card flex flex-col rounded-2xl border border-gray-100 bg-white p-2.5 shadow-sm lg:rounded-4xl lg:p-6">
  <!-- 화면 목업 (모바일은 축소·클립, 데스크톱은 기존 높이) -->
  <div class="mb-2.5 h-32 overflow-hidden rounded-xl lg:mb-6 lg:h-52 lg:overflow-visible lg:rounded-none">
    <slot />
  </div>

  <span class="text-[10px] font-bold uppercase tracking-wider text-coral lg:text-sm">{step}</span>
  <h3 class="mt-1 text-xs font-bold leading-tight text-ink lg:mt-2 lg:text-lg lg:leading-snug">{title}</h3>
  <p class="mt-1 text-[10px] font-light leading-snug text-gray-500 lg:mt-2 lg:text-sm lg:leading-relaxed">{caption}</p>
</article>
