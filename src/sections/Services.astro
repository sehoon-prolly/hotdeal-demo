---
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import ServiceStep from '../components/ServiceStep.astro';
import { services } from '../data/services';
---

<Section id="services" class="reveal">
  <div class="mx-auto mb-14 max-w-2xl text-center md:mb-20">
    <Eyebrow>작동 방식</Eyebrow>
    <h2 class="text-4xl font-bold leading-[1.25] text-ink lg:text-5xl">
      손실을 막는 3단계 프로세스
    </h2>
    <p class="mt-4 text-lg font-medium text-gray-500">
      디자이너님은 <span class="font-bold text-coral">STEP 1</span> 만 해주시면 충분합니다
    </p>
  </div>

  <div class="mx-auto grid max-w-5xl grid-cols-3 gap-2.5 lg:gap-8">
    <!-- STEP 1 : 카카오톡 채팅 목업 -->
    <ServiceStep {...services[0]}>
      <div class="flex h-full flex-col rounded-2xl bg-[#9bbbd4] p-2 lg:p-4">
        <div class="mb-1.5 flex items-center gap-1 lg:mb-3 lg:gap-2">
          <div class="flex h-4 w-4 items-center justify-center rounded-full bg-white/80 text-[8px] font-extrabold text-[#6a90ad] lg:h-7 lg:w-7 lg:text-xs">
            앗
          </div>
          <span class="text-[8px] font-semibold text-white/95 lg:text-xs">앗취 채널</span>
        </div>
        <div class="flex flex-1 flex-col justify-center gap-1 lg:gap-2">
          <div class="flex justify-end">
            <div class="max-w-[88%] rounded-xl rounded-tr-sm bg-[#FEE500] px-2 py-1 text-[9px] font-medium leading-snug text-gray-900 shadow-sm lg:max-w-[82%] lg:rounded-2xl lg:px-3 lg:py-2 lg:text-[13px]">
              오늘 오후 1시~3시 타임 취소됐어요
            </div>
          </div>
          <div class="flex justify-start">
            <div class="max-w-[92%] rounded-xl rounded-tl-sm bg-white px-2 py-1 text-[9px] leading-snug text-gray-700 shadow-sm lg:max-w-[88%] lg:rounded-2xl lg:px-3 lg:py-2 lg:text-[13px]">
              접수됐어요! 바로 핫딜 알림 보낼게요 🚀
            </div>
          </div>
        </div>
      </div>
    </ServiceStep>

    <!-- STEP 2 : 고객 폰 핫딜 푸시 알림 목업 -->
    <ServiceStep {...services[1]}>
      <div class="flex h-full items-center justify-center rounded-2xl bg-gradient-to-br from-gray-800 to-gray-900 p-2 lg:p-4">
        <div class="w-full rounded-xl bg-white/95 p-2 shadow-lg lg:rounded-2xl lg:p-3.5">
          <div class="flex items-center gap-1 lg:gap-2">
            <div class="flex h-4 w-4 items-center justify-center rounded-md bg-coral lg:h-6 lg:w-6 lg:rounded-lg">
              <i class="ph-fill ph-calendar-check text-[8px] text-white lg:text-xs" aria-hidden="true"></i>
            </div>
            <span class="text-[8px] font-bold text-gray-700 lg:text-[11px]">앗취</span>
            <span class="ml-auto text-[8px] text-gray-400 lg:text-[10px]">지금</span>
          </div>
          <p class="mt-1.5 text-[9px] font-bold leading-snug text-gray-900 lg:mt-2.5 lg:text-[13px]">
            📍 가까운 매장에 핫딜이 떴어요!
          </p>
          <p class="mt-1 text-[8px] leading-snug text-gray-500 lg:text-[11px]">
            오후 1시 펌·염색 <span class="text-gray-400 line-through">120,000</span> →
            <span class="font-bold text-coral">89,000원</span>
          </p>
          <span class="mt-1.5 inline-flex items-center gap-0.5 rounded-full bg-coral/10 px-1.5 py-0.5 text-[8px] font-bold text-coral lg:mt-2.5 lg:gap-1 lg:px-2 lg:py-1 lg:text-[10px]">
            <i class="ph ph-lock-simple" aria-hidden="true"></i> 선입금으로 예약 확정
          </span>
        </div>
      </div>
    </ServiceStep>

    <!-- STEP 3 : 정산 완료 카드 목업 -->
    <ServiceStep {...services[2]}>
      <div class="flex h-full flex-col items-center justify-center gap-1.5 rounded-2xl bg-gradient-to-br from-emerald-50 to-teal-50 p-2 lg:gap-3 lg:p-4">
        <div class="flex h-7 w-7 items-center justify-center rounded-full bg-green-500 text-white shadow-lg shadow-green-200 lg:h-12 lg:w-12">
          <i class="ph-fill ph-check-fat text-xs lg:text-xl" aria-hidden="true"></i>
        </div>
        <div class="text-center">
          <p class="text-[8px] font-bold tracking-[0.15em] text-gray-400 lg:text-[11px]">정산 완료</p>
          <p class="mt-0.5 text-base font-extrabold text-gray-900 lg:text-3xl">
            +128,000<span class="text-[10px] lg:text-lg">원</span>
          </p>
          <p class="mt-0.5 text-[8px] text-gray-500 lg:mt-1 lg:text-[11px]">시술 중 자동 입금 완료</p>
        </div>
      </div>
    </ServiceStep>
  </div>
</Section>
