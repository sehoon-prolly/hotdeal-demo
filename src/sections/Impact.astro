---
// '기대 효과' — 사용 방법 다음.
// (1) 시간별(월·연간) 수익 충원 누적 그래프  (2) 이탈하는 신규 고객 → 단골 손님 유치 흐름
// 전부 정적 SVG/CSS (런타임 JS 0). 수익 수치는 예상치(매장 손실 인포그래픽 540만원과 정합).
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';

// 누적 수익 충원 곡선 좌표 (viewBox 340x180, 12개월에 걸쳐 가속 성장)
const line =
  '30,146.9 56.4,141.2 82.7,133.8 109.1,125 135.5,115 161.8,104 188.2,92.1 214.5,79.2 240.9,65.6 267.3,51.1 293.6,35.9 320,20';
---

<Section id="impact" class="reveal">
  <div class="mx-auto mb-12 max-w-2xl text-center md:mb-16">
    <Eyebrow>기대 효과</Eyebrow>
    <h2 class="text-balance text-fluid-h2 font-bold text-ink">
      도입 후, 이렇게 달라집니다
    </h2>
    <p class="mt-4 text-lg font-light text-gray-500">
      사라지던 매출은 회복되고, 손님은 쌓입니다.
    </p>
  </div>

  <div class="mx-auto grid max-w-5xl grid-cols-1 gap-6 lg:grid-cols-2 lg:gap-8">
    <!-- (1) 월·연간 수익 충원 그래프 -->
    <div class="rounded-4xl border border-gray-100 bg-white p-7 shadow-card md:p-8">
      <div class="flex items-center gap-2 text-base font-bold text-ink">
        <i class="ph-fill ph-trend-up text-coral" aria-hidden="true"></i>
        월·연간 수익 충원
      </div>
      <p class="mt-1 text-sm text-gray-500">빈자리를 채울수록 누적 매출이 회복됩니다</p>

      <svg viewBox="0 0 340 180" class="mt-6 h-auto w-full" role="img" aria-label="월별 누적 수익 충원 그래프">
        <!-- 기준선 -->
        <line x1="30" y1="150" x2="320" y2="150" stroke="#E5E7EB" stroke-width="1"></line>
        <!-- 면적 -->
        <polygon points={`30,150 ${line} 320,150`} fill="#FF8B72" fill-opacity="0.12"></polygon>
        <!-- 선 -->
        <polyline points={line} fill="none" stroke="#FF8B72" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></polyline>
        <!-- 정점 -->
        <circle cx="320" cy="20" r="4.5" fill="#FF6B4A"></circle>
        <text x="318" y="14" text-anchor="end" font-size="13" font-weight="700" fill="#FF6B4A">+540만원</text>
        <!-- x축 라벨 -->
        <text x="30" y="170" text-anchor="start" font-size="11" fill="#9CA3AF">1개월</text>
        <text x="175" y="170" text-anchor="middle" font-size="11" fill="#9CA3AF">6개월</text>
        <text x="320" y="170" text-anchor="end" font-size="11" fill="#9CA3AF">12개월</text>
      </svg>

      <div class="mt-6 grid grid-cols-2 gap-3">
        <div class="rounded-2xl bg-coral/5 p-4 text-center">
          <p class="text-xs text-gray-500">월 평균 충원</p>
          <p class="mt-1 text-xl font-extrabold text-coral">+45만원</p>
        </div>
        <div class="rounded-2xl bg-coral/5 p-4 text-center">
          <p class="text-xs text-gray-500">연 누적 충원</p>
          <p class="mt-1 text-xl font-extrabold text-coral">+540만원</p>
        </div>
      </div>
    </div>

    <!-- (2) 이탈하는 신규 고객 → 단골 손님 유치 흐름 -->
    <div class="flex flex-col rounded-4xl border border-gray-100 bg-white p-7 shadow-card md:p-8">
      <div class="flex items-center gap-2 text-base font-bold text-ink">
        <i class="ph-fill ph-users-three text-coral" aria-hidden="true"></i>
        신규 고객을 단골로
      </div>
      <p class="mt-1 text-sm text-gray-500">놓치던 손님을 단골로 이어갑니다</p>

      <div class="flex flex-1 items-center justify-center gap-3 py-8 sm:gap-5">
        <!-- 이탈하는 신규 고객 -->
        <div class="flex w-full max-w-[150px] flex-col items-center gap-3 rounded-2xl bg-gray-50 px-3 py-6 text-center">
          <span class="flex h-12 w-12 items-center justify-center rounded-full bg-gray-200/70">
            <i class="ph ph-user-minus text-2xl text-gray-400" aria-hidden="true"></i>
          </span>
          <span class="text-sm font-semibold leading-snug text-gray-500">이탈하는<br />신규 고객</span>
        </div>

        <!-- 전환 화살표 (앗취) -->
        <div class="flex flex-none flex-col items-center gap-1">
          <span class="text-[11px] font-bold text-coral">앗취</span>
          <i class="ph-bold ph-arrow-right text-2xl text-coral" aria-hidden="true"></i>
        </div>

        <!-- 단골 손님 유치 -->
        <div class="flex w-full max-w-[150px] flex-col items-center gap-3 rounded-2xl bg-coral/5 px-3 py-6 text-center ring-1 ring-coral/20">
          <span class="flex h-12 w-12 items-center justify-center rounded-full bg-coral">
            <i class="ph-fill ph-heart text-2xl text-white" aria-hidden="true"></i>
          </span>
          <span class="text-sm font-bold leading-snug text-ink">단골 손님<br />유치</span>
        </div>
      </div>
    </div>
  </div>

  <p class="mx-auto mt-8 max-w-xl text-center text-xs text-gray-400 md:mt-10">
    * 매장 상황에 따라 실제 효과는 달라질 수 있는 예상 수치입니다.
  </p>
</Section>
