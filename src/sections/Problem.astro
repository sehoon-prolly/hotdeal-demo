---
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import FeatureCard from '../components/FeatureCard.astro';
import LossInfographic from '../components/LossInfographic.astro';
import { problems } from '../data/problems';
---

<Section class="reveal" bg="sand" tight>
  <div class="mb-6 md:mb-12">
    <Eyebrow>매장의 현실</Eyebrow>
    <h2 class="text-4xl font-bold leading-[1.25] text-ink lg:text-5xl">
      월 노쇼 6건, 사장님 매장은 지금 괜찮으신가요?
    </h2>
  </div>

  <!-- 핵심 손실 인포그래픽 (줄글 대신 '보여주기') -->
  <LossInfographic />

  <div class="mt-5 grid grid-cols-3 gap-2.5 md:mt-8 lg:gap-8">
    {problems.map((p) => <FeatureCard {...p} />)}
  </div>
</Section>
