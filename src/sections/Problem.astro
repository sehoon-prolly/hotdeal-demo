---
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import LossInfographic from '../components/LossInfographic.astro';
import { testimonials } from '../data/testimonials';
---

<Section class="reveal" bg="sand" tight>
  <div class="mx-auto mb-10 max-w-2xl text-center md:mb-14">
    <Eyebrow>매장의 현실</Eyebrow>
    <h2 class="text-balance text-fluid-h2 font-bold text-ink">
      예약 취소, 변경의 문제들<br />괜찮으신가요?
    </h2>
  </div>

  <!-- 핵심 손실 인포그래픽 (줄글 대신 '보여주기') -->
  <div class="mx-auto max-w-5xl">
    <LossInfographic />
  </div>

  <!-- 현장 사장님들의 목소리 -->
  <div class="mx-auto mt-8 grid max-w-5xl grid-cols-2 items-start gap-3 md:mt-12 lg:gap-8">
    {testimonials.map((t) => <TestimonialCard {...t} />)}
  </div>
</Section>
