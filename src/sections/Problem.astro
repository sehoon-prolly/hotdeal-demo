---
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import FeatureCard from '../components/FeatureCard.astro';
import LossInfographic from '../components/LossInfographic.astro';
import { problems } from '../data/problems';
---

<Section class="reveal" bg="sand" tight>
  <div class="mx-auto mb-10 max-w-2xl text-center md:mb-14">
    <Eyebrow>매장의 현실</Eyebrow>
    <h2 class="text-balance text-4xl font-bold leading-[1.25] text-ink lg:text-5xl">
      괜찮으신가요?
    </h2>
  </div>

  <!-- 핵심 손실 인포그래픽 (줄글 대신 '보여주기') -->
  <div class="mx-auto max-w-5xl">
    <LossInfographic />
  </div>

  <div class="mx-auto mt-8 grid max-w-5xl grid-cols-1 gap-5 md:mt-12 lg:grid-cols-3 lg:gap-8">
    {problems.map((p) => <FeatureCard {...p} />)}
  </div>
</Section>
