---
import { hero } from '../data/site';
import HotDealMockup from '../components/HotDealMockup.astro';
---

<section
  id="top"
  class="mx-auto max-w-container px-6 pb-20 pt-10 text-center md:px-12 md:pb-28 md:pt-16"
>
  <div class="mx-auto max-w-3xl">
    <!-- 라이브 뱃지 -->
    <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-coral/10 px-3 py-1 text-xs font-bold uppercase tracking-wider text-coral">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-coral opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-coral"></span>
      </span>
      {hero.badge}
    </div>

    <h1 class="mb-8 text-balance text-fluid-hero font-bold leading-[1.18] text-ink">
      {hero.titleLine1}<br /><span class="text-coral">{hero.titleAccent}</span>
    </h1>

    <p class="mx-auto mb-10 max-w-2xl text-lg font-light leading-relaxed text-gray-500 lg:text-xl">
      {hero.description}
    </p>

    <!-- 핵심 수치 -->
    <div class="mx-auto max-w-xl border-t border-gray-200 pt-8">
      <div class="grid grid-cols-3 gap-8">
        {
          hero.stats.map((s) => (
            <div>
              <div class="text-xl font-bold text-ink lg:text-2xl">{s.value}</div>
              <div class="mt-1 text-xs leading-snug text-gray-400">{s.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- 핫딜 알림 목업: 텍스트 아래 중앙 / 폰이 다 드러나면 알림 팝업 등장 (스크롤 기반) -->
  <div class="mt-16 md:mt-20">
    <HotDealMockup />
  </div>
</section>
