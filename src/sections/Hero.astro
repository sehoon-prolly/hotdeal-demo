---
import { hero } from '../data/site';
import Button from '../components/Button.astro';
import DashboardMockup from '../components/DashboardMockup.astro';
---

<section
  id="top"
  class="mx-auto grid max-w-container grid-cols-1 items-center gap-16 px-6 pb-20 pt-8 md:px-12 md:pb-24 md:pt-12 lg:grid-cols-2"
>
  <div class="max-w-xl">
    <!-- 라이브 뱃지 -->
    <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-coral/10 px-3 py-1 text-xs font-bold uppercase tracking-wider text-coral">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-coral opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-coral"></span>
      </span>
      {hero.badge}
    </div>

    <h1 class="mb-8 text-5xl font-bold leading-[1.2] text-ink lg:text-6xl">
      {hero.titlePre}<br />
      <span class="text-coral">{hero.titleHighlight}</span><br />{hero.titlePost}
    </h1>

    <p class="mb-10 text-lg font-light leading-relaxed text-gray-500 lg:text-xl">
      {hero.description}
    </p>

    <div class="flex flex-col items-center gap-4 sm:flex-row">
      <Button variant="primary" href="#apply" class="w-full sm:w-auto">
        {hero.ctaLabel}
        <i class="ph ph-arrow-right font-bold" aria-hidden="true"></i>
      </Button>
    </div>

    <!-- 핵심 수치 -->
    <div class="mt-12 border-t border-gray-200 pt-8">
      <div class="grid grid-cols-3 gap-8">
        {
          hero.stats.map((s) => (
            <div>
              <div class="text-xl font-bold text-ink lg:text-2xl">{s.value}</div>
              <div class="mt-1 text-xs leading-snug text-gray-400">{s.label}</div>
            </div>
          ))
        }
      </div>
      <p class="mt-4 text-[10px] text-gray-300">{hero.statsNote}</p>
    </div>
  </div>

  <DashboardMockup />
</section>
