---
import { hero } from '../data/site';

// 히어로 하단 섹션 바로가기 버튼 (클릭 시 해당 섹션으로 스크롤)
const jump = [
  { label: '매장의 현실', href: '#problem' },
  { label: '예약금 솔루션의 한계', href: '#deposit-limit' },
  { label: '사용 방법', href: '#services' },
  { label: '예상 기대 효과', href: '#impact' },
  { label: '자주 묻는 걱정', href: '#reassurance' },
  { label: '도움말', href: '#faq' },
];
---

<section
  id="top"
  class="mx-auto max-w-container px-6 pb-20 pt-10 text-center md:px-12 md:pb-28 md:pt-16"
>
  <div class="mx-auto max-w-3xl">
    <!-- 라이브 뱃지 -->
    <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-coral/10 px-3 py-1 text-xs font-bold uppercase tracking-wider text-coral">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-coral opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-coral"></span>
      </span>
      {hero.badge}
    </div>

    <h1 class="mb-8 text-balance text-fluid-hero font-bold leading-[1.18] text-ink">
      {hero.titleLine1}<br /><span class="text-coral">{hero.titleAccent}</span>
    </h1>

    <p class="mx-auto mb-10 max-w-2xl text-lg font-light leading-relaxed text-gray-500 lg:text-xl">
      {hero.description}
    </p>

    <!-- 핵심 수치 -->
    <div class="mx-auto max-w-xl border-t border-gray-200 pt-8">
      <div class="grid grid-cols-3 gap-8">
        {
          hero.stats.map((s) => (
            <div>
              <div class="text-xl font-bold text-ink lg:text-2xl">{s.value}</div>
              <div class="mt-1 text-xs leading-snug text-gray-400">{s.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- 섹션 바로가기 버튼: 클릭하면 해당 섹션으로 스크롤 -->
  <div class="mt-14 md:mt-16">
    <p class="mb-5 text-sm font-medium text-gray-400">아래 내용을 바로 확인해 보세요</p>
    <div class="mx-auto flex max-w-2xl flex-wrap justify-center gap-2.5 md:gap-3">
      {
        jump.map((j) => (
          <a
            href={j.href}
            class="group inline-flex items-center gap-1.5 rounded-full border border-gray-200 bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 shadow-sm transition hover:-translate-y-0.5 hover:border-coral hover:text-coral"
          >
            {j.label}
            <i
              class="ph ph-arrow-down text-gray-400 transition group-hover:translate-y-0.5 group-hover:text-coral"
              aria-hidden="true"
            />
          </a>
        ))
      }
    </div>
  </div>
</section>
