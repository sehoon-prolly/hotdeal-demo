---
import { trustBar } from '../data/site';
---

<section
  class="flex w-full flex-wrap items-center justify-center gap-12 border-t border-gray-100 bg-white/50 px-6 py-12 opacity-80 grayscale transition-all duration-700 hover:grayscale-0 md:px-12 lg:gap-24"
>
  {
    trustBar.logos.map((logo) => (
      <div class="flex items-center gap-2">
        <i class:list={['ph', logo.icon, 'text-3xl']} aria-hidden="true" />
        <span class="font-serif text-xl font-bold">{logo.name}</span>
      </div>
    ))
  }
</section>
