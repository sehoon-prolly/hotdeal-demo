---
// FAQ — 2단 레이아웃(좌: 제목·안내 / 우: 아코디언). 네이티브 <details>로 JS 0.
// 답변은 set:html 렌더(부분 강조 <strong> 지원). caret 회전은 global.css.
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import { faqs } from '../data/faq';
import { contactFormUrl } from '../data/site';
---

<Section id="faq" class="reveal" tight>
  <!--
    모바일: 세로 순서 = 제목 → 아코디언 → 문의 카드 (DOM 순서대로 stack).
    데스크톱(lg): 2단 그리드 — 좌측(제목+문의카드) / 우측(아코디언 전체높이).
    명시적 grid 배치로 데스크톱은 기존 레이아웃 유지하면서 모바일 순서만 다르게.
  -->
  <div class="space-y-8 lg:grid lg:grid-cols-[1fr_1.6fr] lg:gap-x-16 lg:gap-y-8 lg:space-y-0">
    <!-- ① 제목 + 안내 (모바일 최상단 / 데스크톱 좌상단) -->
    <div class="lg:col-start-1 lg:row-start-1">
      <Eyebrow>도움말</Eyebrow>
      <h2 class="text-4xl font-bold leading-[1.25] text-ink lg:text-5xl">자주 묻는 질문</h2>
      <p class="mt-4 text-base font-light leading-relaxed text-gray-500">
        더 궁금한 점은 편하게 문의해 주세요.
      </p>
    </div>

    <!-- ② 아코디언 (모바일 가운데 / 데스크톱 우측 전체높이) -->
    <div class="space-y-2.5 lg:col-start-2 lg:row-start-1 lg:row-span-2 lg:space-y-4">
      {
        faqs.map((f) => (
          <details class="rounded-3xl border border-gray-100 bg-white px-6 py-4 shadow-sm lg:px-8 lg:py-6">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-bold text-ink [&::-webkit-details-marker]:hidden lg:text-lg">
              <span>{f.question}</span>
              <i
                class="ph ph-caret-down faq-caret shrink-0 text-xl text-coral"
                aria-hidden="true"
              />
            </summary>
            <p class="mt-4 text-sm font-light leading-relaxed text-gray-500 lg:text-base" set:html={f.answer} />
          </details>
        ))
      }
    </div>

    <!-- ③ 문의 카드 (모바일 최하단 / 데스크톱 좌하단) -->
    <div class="lg:col-start-1 lg:row-start-2">
      <div class="rounded-3xl border border-coral/20 bg-coral/5 p-5 text-center lg:p-7 lg:text-left">
        <div class="mx-auto flex h-11 w-11 items-center justify-center rounded-2xl bg-coral/15 lg:mx-0">
          <i class="ph-fill ph-chat-circle-dots text-2xl text-coral" aria-hidden="true"></i>
        </div>
        <p class="mt-3 text-lg font-bold text-ink lg:mt-4">아직 궁금한 게 남으셨나요?</p>
        <p class="mt-2 text-sm font-light leading-relaxed text-gray-500">
          카톡 한 줄이면 상담 끝. 30초면 충분합니다.
        </p>
        <a
          href={contactFormUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-2 rounded-2xl bg-coral-dark px-6 py-3.5 text-base font-bold text-white transition-all hover:gap-3 lg:mt-5"
        >
          문의하기 <i class="ph ph-arrow-right" aria-hidden="true"></i>
        </a>
      </div>
    </div>
  </div>
</Section>
