---
// FAQ — 중앙 단일 컬럼(제목 → 아코디언 → 문의 카드). 네이티브 <details>로 JS 0.
// 답변은 set:html 렌더(부분 강조 <strong> 지원). caret 회전은 global.css.
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import { faqs } from '../data/faq';
import { contactFormUrl } from '../data/site';
---

<Section id="faq" class="reveal" tight>
  <!-- 제목 (중앙) -->
  <div class="mx-auto mb-10 max-w-2xl text-center md:mb-14">
    <Eyebrow>도움말</Eyebrow>
    <h2 class="text-4xl font-bold leading-[1.25] text-ink lg:text-5xl">자주 묻는 질문</h2>
    <p class="mt-4 text-base font-light leading-relaxed text-gray-500">
      더 궁금한 점은 편하게 문의해 주세요.
    </p>
  </div>

  <!-- 아코디언 (중앙, 폭 제한) -->
  <div class="mx-auto max-w-3xl space-y-3 text-left">
    {
      faqs.map((f) => (
        <details class="rounded-3xl border border-gray-100 bg-white px-6 py-4 shadow-sm lg:px-8 lg:py-6">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-bold text-ink [&::-webkit-details-marker]:hidden lg:text-lg">
            <span>{f.question}</span>
            <i
              class="ph ph-caret-down faq-caret shrink-0 text-xl text-coral"
              aria-hidden="true"
            />
          </summary>
          <p class="mt-4 text-sm font-light leading-relaxed text-gray-500 lg:text-base" set:html={f.answer} />
        </details>
      ))
    }
  </div>

  <!-- 문의 카드 (중앙) -->
  <div class="mx-auto mt-8 max-w-xl">
    <div class="rounded-3xl border border-coral/20 bg-coral/5 p-7 text-center">
      <div class="mx-auto flex h-11 w-11 items-center justify-center rounded-2xl bg-coral/15">
        <i class="ph-fill ph-chat-circle-dots text-2xl text-coral" aria-hidden="true"></i>
      </div>
      <p class="mt-4 text-lg font-bold text-ink">아직 궁금한 게 남으셨나요?</p>
      <p class="mt-2 text-sm font-light leading-relaxed text-gray-500">
        카톡 한 줄이면 상담 끝. 30초면 충분합니다.
      </p>
      <a
        href={contactFormUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-5 inline-flex items-center gap-2 rounded-2xl bg-coral-dark px-6 py-3.5 text-base font-bold text-white transition-all hover:gap-3"
      >
        문의하기 <i class="ph ph-arrow-right" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</Section>
