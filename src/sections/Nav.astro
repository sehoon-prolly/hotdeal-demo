---
// 미니멀 헤더 — 랜딩 집중을 위해 내비 링크·햄버거 제거, 로고 + 단일 CTA만 유지
import { brand, nav, contactFormUrl } from '../data/site';
import Button from '../components/Button.astro';
---

<header class="relative">
  <nav class="mx-auto flex max-w-container items-center justify-between px-6 py-6 md:px-12 md:py-8">
    <!-- 로고 -->
    <a href="#top" class="flex items-center gap-2">
      <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-coral shadow-sm">
        <i class:list={['ph-fill', brand.icon, 'text-2xl text-white']} aria-hidden="true"></i>
      </div>
      <span class="text-xl font-bold tracking-tight text-ink">{brand.name}</span>
      <span class="hidden text-xs font-medium text-gray-400 sm:inline">{brand.tagline}</span>
    </a>

    <!-- 단일 CTA -->
    <Button variant="outline" href={contactFormUrl} target="_blank">{nav.ctaLabel}</Button>
  </nav>
</header>
