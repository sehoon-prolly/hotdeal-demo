---
// 우측 고정 섹션 바로가기 (화면 중앙, 스크롤 내내 따라다님).
// 점에 호버하면 섹션 이름 라벨이 나타나고, 클릭하면 해당 섹션으로 스크롤(zero-JS 앵커).
// 데스크톱 전용 — 좁은 모바일에서는 콘텐츠와 겹치지 않도록 숨김.
const items = [
  { label: '매장의 현실', href: '#problem' },
  { label: '예약금 솔루션의 한계', href: '#deposit-limit' },
  { label: '사용 방법', href: '#services' },
  { label: '예상 기대 효과', href: '#impact' },
  { label: '자주 묻는 걱정', href: '#reassurance' },
  { label: '도움말', href: '#faq' },
];
---

<nav
  aria-label="섹션 바로가기"
  class="fixed right-5 top-1/2 z-40 hidden -translate-y-1/2 lg:block"
>
  <ul class="flex flex-col items-end gap-3.5">
    {
      items.map((it) => (
        <li>
          <a href={it.href} class="group flex items-center justify-end gap-2.5">
            <span class="pointer-events-none translate-x-1 whitespace-nowrap rounded-full bg-ink/85 px-2.5 py-1 text-xs font-semibold text-white opacity-0 shadow-sm backdrop-blur-sm transition-all duration-200 group-hover:translate-x-0 group-hover:opacity-100">
              {it.label}
            </span>
            <span class="h-3 w-3 flex-none rounded-full border-2 border-gray-300 bg-white/70 transition-all duration-200 group-hover:scale-125 group-hover:border-coral group-hover:bg-coral" />
          </a>
        </li>
      ))
    }
  </ul>
</nav>
