---
// '자주 묻는 걱정' — 할인이 단골/기존 관계를 해치지 않는다는 안심 + 비교표.
// (whattime 레퍼런스 구성, 색감은 코랄 팔레트로 이식 / 페이지 톤에 맞춰 전체 중앙정렬)
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';

const points = [
  {
    title: '빈 슬롯에만 적용',
    body: '취소된 자리에만 핫딜을 적용합니다. 정상 예약 슬롯에는 노출되지 않습니다.',
  },
  {
    title: '신규 고객만 타겟',
    body: '단골 고객은 이 할인의 존재 자체를 알 수 없습니다. 기존 관계를 전혀 해치지 않습니다.',
  },
];

const rows = [
  { label: '공실 시간', off: '그대로 손해', on: '새 고객 방문' },
  { label: '선입금 여부', off: '없음', on: '결제 완료 후 예약' },
  { label: '단골 영향', off: '없음', on: '단골은 모름' },
  { label: '비용 발생', off: '없음', on: '수익 발생 시만' },
];
---

<Section id="reassurance" class="reveal" bg="sand">
  <!-- 헤더 (중앙정렬) -->
  <div class="mx-auto mb-12 max-w-2xl text-center md:mb-16">
    <Eyebrow>자주 묻는 걱정</Eyebrow>
    <h2 class="text-fluid-h2 font-bold text-ink">
      할인하면 단골이<br />기다리지 않을까요?
    </h2>
  </div>

  <!-- 안심 포인트 (중앙정렬) -->
  <div class="mx-auto grid max-w-3xl grid-cols-1 gap-8 sm:grid-cols-2">
    {
      points.map((p) => (
        <div class="text-center">
          <span class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-coral/10">
            <i class="ph-fill ph-check-fat text-lg text-coral" aria-hidden="true" />
          </span>
          <p class="text-lg font-bold text-ink">{p.title}</p>
          <p class="mt-2 leading-relaxed text-gray-500">{p.body}</p>
        </div>
      ))
    }
  </div>

  <!-- 비교표 (중앙) -->
  <div
    class="mx-auto mt-12 max-w-2xl overflow-hidden rounded-3xl border border-gray-100 bg-white shadow-card md:mt-16"
  >
    <!-- 헤더 -->
    <div class="grid grid-cols-[1.05fr_1fr_1fr] text-center">
      <div class="bg-white"></div>
      <div class="bg-gray-50 px-3 py-5">
        <p class="text-xs font-medium text-gray-400 md:text-sm">아무것도 안 할 때</p>
        <p class="mt-1 text-2xl font-bold text-gray-300 md:text-3xl">0원</p>
      </div>
      <div class="bg-coral/5 px-3 py-5">
        <p class="text-xs font-bold text-coral md:text-sm">앗취로 채울 때</p>
        <p class="mt-1 text-2xl font-extrabold text-coral md:text-3xl">+매출</p>
      </div>
    </div>

    <!-- 본문 -->
    {
      rows.map((r) => (
        <div class="grid grid-cols-[1.05fr_1fr_1fr] items-center border-t border-gray-100 text-center">
          <div class="px-4 py-4 text-left text-sm font-medium text-gray-600 md:px-6 md:text-base">
            {r.label}
          </div>
          <div class="px-2 py-4 text-xs text-gray-400 md:text-sm">{r.off}</div>
          <div class="self-stretch bg-coral/5 px-2 py-4 text-xs font-bold text-coral md:text-sm">
            {r.on}
          </div>
        </div>
      ))
    }
  </div>

  <!-- 마무리 한 줄 (중앙정렬) -->
  <p
    class="mx-auto mt-12 max-w-xl text-center text-xl font-bold leading-snug text-ink md:mt-14"
  >
    어차피 사라질 자리로<br />새 손님을 만드는 것입니다.
  </p>
</Section>
