---
import '../styles/global.css';
// Phosphor 아이콘 — npm 패키지로 자체 호스팅 (CDN 런타임 의존 제거 → 안정성)
import '@phosphor-icons/web/regular';
import '@phosphor-icons/web/fill';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'FillEmpty — 예약이 취소되는 순간, 30분 안에 예약이 채워집니다',
  description = '직전취소·노쇼가 발생하면 알림 한 번으로 대기 고객이 스스로 예약합니다. 미용실·네일샵을 위한 자동 핫딜 알림 서비스.',
} = Astro.props;

const ogImage = new URL('/og-image.png', Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / 링크 공유 미리보기 -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ko_KR" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- 폰트: Inter(라틴/숫자) + Noto Sans KR(한글) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+KR:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="min-h-screen w-full overflow-x-hidden bg-cream font-sans text-ink antialiased"
  >
    <slot />
  </body>
</html>
